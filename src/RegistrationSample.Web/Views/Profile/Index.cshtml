@model RegistrationSample.Web.Models.UserProfileViewModel
@{
    ViewData["Title"] = "My Profile";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row mb-4">
    <div class="col-12 d-flex justify-content-between align-items-center">
        <h2><i class="fas fa-user-circle me-2 text-primary"></i>My Profile</h2>
        <a href="/Profile/Edit" class="btn btn-primary">
            <i class="fas fa-edit me-2"></i>Update Info
        </a>
    </div>
</div>

<div class="row">
    <div class="col-md-4 mb-4">
        <div class="card text-center p-4">
            <div class="d-flex justify-content-center mb-3">
                @if (!string.IsNullOrEmpty(Model?.ProfilePictureUrl))
                {
                    <img src="@Model.ProfilePictureUrl" alt="Profile Picture"
                         class="rounded-circle" style="width:100px;height:100px;object-fit:cover;" />
                }
                else
                {
                    <div class="profile-avatar">
                        @(Model?.FirstName?.Substring(0, 1).ToUpper())@(Model?.LastName?.Substring(0, 1).ToUpper())
                    </div>
                }
            </div>
            <h4>@Model?.FirstName @Model?.LastName</h4>
            <p class="text-muted mb-1"><i class="fas fa-envelope me-1"></i>@Model?.Email</p>
            <p class="text-muted mb-0"><i class="fas fa-graduation-cap me-1"></i>@Model?.Degree</p>
            <hr />
            <div class="text-start">
                <small class="text-muted">Member since: @Model?.CreatedAt.ToString("MMM dd, yyyy")</small><br/>
                <small class="text-muted">Last updated: @Model?.UpdatedAt.ToString("MMM dd, yyyy")</small>
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0"><i class="fas fa-user me-2 text-primary"></i>Personal Information</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-sm-6 mb-3">
                        <div class="info-label">First Name</div>
                        <div class="info-value">@Model?.FirstName</div>
                    </div>
                    <div class="col-sm-6 mb-3">
                        <div class="info-label">Last Name</div>
                        <div class="info-value">@Model?.LastName</div>
                    </div>
                    <div class="col-sm-6 mb-3">
                        <div class="info-label">Middle Name</div>
                        <div class="info-value">@(string.IsNullOrEmpty(Model?.MiddleName) ? "—" : Model?.MiddleName)</div>
                    </div>
                    <div class="col-sm-6 mb-3">
                        <div class="info-label">Date of Birth</div>
                        <div class="info-value">@Model?.DateOfBirth.ToString("MMMM dd, yyyy")</div>
                    </div>
                    <div class="col-sm-6 mb-3">
                        <div class="info-label">Gender</div>
                        <div class="info-value">@Model?.Gender</div>
                    </div>
                    <div class="col-sm-6 mb-3">
                        <div class="info-label">Marital Status</div>
                        <div class="info-value">@(string.IsNullOrEmpty(Model?.MaritalStatus) ? "—" : Model?.MaritalStatus)</div>
                    </div>
                    <div class="col-sm-6 mb-3">
                        <div class="info-label">Phone</div>
                        <div class="info-value">@(string.IsNullOrEmpty(Model?.Phone) ? "—" : Model?.Phone)</div>
                    </div>
                    <div class="col-sm-6 mb-3">
                        <div class="info-label">Country</div>
                        <div class="info-value">@(string.IsNullOrEmpty(Model?.Country) ? "—" : Model?.Country)</div>
                    </div>
                    <div class="col-12 mb-3">
                        <div class="info-label">Address</div>
                        <div class="info-value">
                            @if (!string.IsNullOrEmpty(Model?.Address))
                            {
                                @Model.Address
                                @if (!string.IsNullOrEmpty(Model?.City)) { <text>, @Model.City</text> }
                                @if (!string.IsNullOrEmpty(Model?.State)) { <text>, @Model.State</text> }
                                @if (!string.IsNullOrEmpty(Model?.PostalCode)) { <text> @Model.PostalCode</text> }
                            }
                            else { <span>—</span> }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0"><i class="fas fa-briefcase me-2 text-primary"></i>Professional Information</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-sm-6 mb-3">
                        <div class="info-label">Occupation</div>
                        <div class="info-value">@(string.IsNullOrEmpty(Model?.Occupation) ? "—" : Model?.Occupation)</div>
                    </div>
                    <div class="col-sm-6 mb-3">
                        <div class="info-label">Employer</div>
                        <div class="info-value">@(string.IsNullOrEmpty(Model?.Employer) ? "—" : Model?.Employer)</div>
                    </div>
                    <div class="col-sm-6 mb-3">
                        <div class="info-label">Years of Experience</div>
                        <div class="info-value">@(Model?.YearsOfExperience == 0 ? "—" : Model?.YearsOfExperience.ToString())</div>
                    </div>
                    <div class="col-sm-6 mb-3">
                        <div class="info-label">LinkedIn</div>
                        <div class="info-value">
                            @if (!string.IsNullOrEmpty(Model?.LinkedInUrl))
                            {
                                <a href="@Model.LinkedInUrl" target="_blank" rel="noopener noreferrer">@Model.LinkedInUrl</a>
                            }
                            else { <span>—</span> }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <h5 class="mb-0"><i class="fas fa-graduation-cap me-2 text-primary"></i>Academic Information</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-sm-6 mb-3">
                        <div class="info-label">Institution</div>
                        <div class="info-value">@(string.IsNullOrEmpty(Model?.Institution) ? "—" : Model?.Institution)</div>
                    </div>
                    <div class="col-sm-6 mb-3">
                        <div class="info-label">Degree</div>
                        <div class="info-value">@(string.IsNullOrEmpty(Model?.Degree) ? "—" : Model?.Degree)</div>
                    </div>
                    <div class="col-sm-6 mb-3">
                        <div class="info-label">Field of Study</div>
                        <div class="info-value">@(string.IsNullOrEmpty(Model?.FieldOfStudy) ? "—" : Model?.FieldOfStudy)</div>
                    </div>
                    <div class="col-sm-6 mb-3">
                        <div class="info-label">Graduation Year</div>
                        <div class="info-value">@(Model?.GraduationYear == 0 ? "—" : Model?.GraduationYear.ToString())</div>
                    </div>
                    <div class="col-sm-4 mb-3">
                        <div class="info-label">GPA</div>
                        <div class="info-value">@(string.IsNullOrEmpty(Model?.GradePointAverage) ? "—" : Model?.GradePointAverage)</div>
                    </div>
                    <div class="col-sm-4 mb-3">
                        <div class="info-label">Student ID</div>
                        <div class="info-value">@(string.IsNullOrEmpty(Model?.StudentId) ? "—" : Model?.StudentId)</div>
                    </div>
                    <div class="col-sm-4 mb-3">
                        <div class="info-label">Academic Year</div>
                        <div class="info-value">@(string.IsNullOrEmpty(Model?.AcademicYear) ? "—" : Model?.AcademicYear)</div>
                    </div>
                    @if (!string.IsNullOrEmpty(Model?.Certifications))
                    {
                        <div class="col-12 mb-3">
                            <div class="info-label">Certifications</div>
                            <div class="info-value">@Model.Certifications</div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
