@model RegistrationSample.Web.Models.EditProfileViewModel
@{
    ViewData["Title"] = "Edit Profile";
}

<div class="row justify-content-center">
    <div class="col-md-10">
        <div class="d-flex align-items-center mb-4">
            <a href="/Profile" class="btn btn-outline-secondary me-3">
                <i class="fas fa-arrow-left me-1"></i>Back
            </a>
            <h2 class="mb-0"><i class="fas fa-edit me-2 text-primary"></i>Edit Profile</h2>
        </div>

        <div class="card">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">Update Your Information</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="Edit" method="post">
                    @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
                    {
                        <div class="alert alert-danger">
                            <div asp-validation-summary="All"></div>
                        </div>
                    }

                    <h5 class="section-title"><i class="fas fa-user me-2"></i>Personal Information</h5>
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label asp-for="FirstName" class="form-label">First Name <span class="text-muted small">(cannot be changed)</span></label>
                            <input asp-for="FirstName" class="form-control bg-light" disabled />
                            <input asp-for="FirstName" type="hidden" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="MiddleName" class="form-label">Middle Name <span class="text-muted small">(cannot be changed)</span></label>
                            <input asp-for="MiddleName" class="form-control bg-light" disabled />
                            <input asp-for="MiddleName" type="hidden" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="LastName" class="form-label">Last Name <span class="text-muted small">(cannot be changed)</span></label>
                            <input asp-for="LastName" class="form-control bg-light" disabled />
                            <input asp-for="LastName" type="hidden" />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="DateOfBirth" class="form-label">Date of Birth</label>
                            <input asp-for="DateOfBirth" type="date" class="form-control" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Gender" class="form-label">Gender</label>
                            <select asp-for="Gender" class="form-select">
                                <option value="">-- Select --</option>
                                <option value="Male">Male</option>
                                <option value="Female">Female</option>
                                <option value="Prefer not to say">Prefer not to say</option>
                            </select>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="MaritalStatus" class="form-label">Marital Status</label>
                            <select asp-for="MaritalStatus" class="form-select">
                                <option value="">-- Select --</option>
                                <option value="Single">Single</option>
                                <option value="Married">Married</option>
                                <option value="Divorced">Divorced</option>
                                <option value="Widowed">Widowed</option>
                                <option value="Prefer not to say">Prefer not to say</option>
                            </select>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Phone" class="form-label">Phone Number</label>
                        <input asp-for="Phone" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="ProfilePictureUrl" class="form-label">Profile Picture URL</label>
                        <input asp-for="ProfilePictureUrl" class="form-control" placeholder="https://example.com/photo.jpg" />
                        <span asp-validation-for="ProfilePictureUrl" class="text-danger small"></span>
                    </div>

                    <h5 class="section-title mt-3"><i class="fas fa-map-marker-alt me-2"></i>Address</h5>
                    <div class="mb-3">
                        <label asp-for="Address" class="form-label">Street Address</label>
                        <input asp-for="Address" class="form-control" />
                    </div>
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label asp-for="City" class="form-label">City</label>
                            <input asp-for="City" class="form-control" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="State" class="form-label">State</label>
                            <input asp-for="State" class="form-control" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="PostalCode" class="form-label">Postal Code</label>
                            <input asp-for="PostalCode" class="form-control" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Country" class="form-label">Country</label>
                        <input asp-for="Country" class="form-control" />
                    </div>

                    <h5 class="section-title mt-3"><i class="fas fa-briefcase me-2"></i>Professional Information</h5>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Occupation" class="form-label">Occupation</label>
                            <input asp-for="Occupation" class="form-control" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Employer" class="form-label">Employer / Company</label>
                            <input asp-for="Employer" class="form-control" />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="YearsOfExperience" class="form-label">Years of Experience</label>
                            <input asp-for="YearsOfExperience" type="number" class="form-control" min="0" max="60" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="LinkedInUrl" class="form-label">LinkedIn Profile URL</label>
                            <input asp-for="LinkedInUrl" class="form-control" />
                            <span asp-validation-for="LinkedInUrl" class="text-danger small"></span>
                        </div>
                    </div>

                    <h5 class="section-title mt-3"><i class="fas fa-graduation-cap me-2"></i>Academic Information</h5>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Institution" class="form-label">Institution</label>
                            <input asp-for="Institution" class="form-control" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Degree" class="form-label">Degree</label>
                            <select asp-for="Degree" class="form-select">
                                <option value="">-- Select --</option>
                                <option value="High School Diploma">High School Diploma</option>
                                <option value="Associate's">Associate's</option>
                                <option value="Bachelor's">Bachelor's</option>
                                <option value="Master's">Master's</option>
                                <option value="Doctorate">Doctorate</option>
                                <option value="Professional">Professional</option>
                                <option value="Certificate">Certificate</option>
                            </select>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="FieldOfStudy" class="form-label">Field of Study</label>
                            <input asp-for="FieldOfStudy" class="form-control" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="GraduationYear" class="form-label">Graduation Year</label>
                            <input asp-for="GraduationYear" type="number" class="form-control" min="1950" max="2040" />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label asp-for="GradePointAverage" class="form-label">GPA</label>
                            <input asp-for="GradePointAverage" class="form-control" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="StudentId" class="form-label">Student ID</label>
                            <input asp-for="StudentId" class="form-control" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="AcademicYear" class="form-label">Academic Year</label>
                            <select asp-for="AcademicYear" class="form-select">
                                <option value="">-- Select --</option>
                                <option value="100lvl (Freshman)">100lvl (Freshman)</option>
                                <option value="200lvl (Sophomore)">200lvl (Sophomore)</option>
                                <option value="300lvl (Junior)">300lvl (Junior)</option>
                                <option value="400lvl (Senior)">400lvl (Senior)</option>
                                <option value="500lvl (Senior)">500lvl (Senior)</option>
                                <option value="600lvl (Senior)">600lvl (Senior)</option>
                                <option value="Postgraduate">Postgraduate</option>
                                <option value="Graduate">Graduate</option>
                                <option value="Alumni">Alumni</option>
                            </select>
                        </div>
                    </div>
                    <div class="mb-4">
                        <label asp-for="Certifications" class="form-label">Certifications</label>
                        <textarea asp-for="Certifications" class="form-control" rows="3"></textarea>
                    </div>

                    <div class="d-flex gap-3">
                        <button type="submit" class="btn btn-primary btn-lg">
                            <i class="fas fa-save me-2"></i>Save Changes
                        </button>
                        <a href="/Profile" class="btn btn-outline-secondary btn-lg">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
