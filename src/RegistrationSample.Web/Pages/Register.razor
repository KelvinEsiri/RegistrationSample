@page "/account/register"

<PageTitle>Register</PageTitle>

<div class="row justify-content-center">
    <div class="col-md-10 col-lg-9">
        <div class="card my-4">
            <div class="card-header bg-primary text-white">
                <h4 class="mb-0"><i class="fas fa-user-plus me-2"></i>Create Your Account</h4>
            </div>
            <div class="card-body p-4">
                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="alert alert-danger">@errorMessage</div>
                }

                <EditForm Model="model" OnValidSubmit="HandleRegister">
                    <DataAnnotationsValidator />

                    <!-- Personal Information -->
                    <h5 class="section-title"><i class="fas fa-user me-2"></i>Personal Information</h5>
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label">First Name <span class="text-danger">*</span></label>
                            <InputText @bind-Value="model.FirstName" class="form-control" placeholder="Enter first name" />
                            <ValidationMessage For="() => model.FirstName" class="text-danger small" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Middle Name</label>
                            <InputText @bind-Value="model.MiddleName" class="form-control" placeholder="Enter middle name" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Last Name <span class="text-danger">*</span></label>
                            <InputText @bind-Value="model.LastName" class="form-control" placeholder="Enter last name" />
                            <ValidationMessage For="() => model.LastName" class="text-danger small" />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Email Address <span class="text-danger">*</span></label>
                            <InputText @bind-Value="model.Email" class="form-control" placeholder="you@example.com" />
                            <ValidationMessage For="() => model.Email" class="text-danger small" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Phone Number</label>
                            <InputText @bind-Value="model.Phone" class="form-control" placeholder="+1 234 567 8900" />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Password <span class="text-danger">*</span></label>
                            <input type="password" class="form-control" @bind="model.Password" placeholder="Min 8 characters" />
                            <ValidationMessage For="() => model.Password" class="text-danger small" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Confirm Password <span class="text-danger">*</span></label>
                            <input type="password" class="form-control" @bind="model.ConfirmPassword" placeholder="Repeat password" />
                            <ValidationMessage For="() => model.ConfirmPassword" class="text-danger small" />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Date of Birth <span class="text-danger">*</span></label>
                            <InputDate @bind-Value="model.DateOfBirth" class="form-control" />
                            <ValidationMessage For="() => model.DateOfBirth" class="text-danger small" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Gender <span class="text-danger">*</span></label>
                            <InputSelect @bind-Value="model.Gender" class="form-select">
                                <option value="">-- Select Gender --</option>
                                <option value="Male">Male</option>
                                <option value="Female">Female</option>
                                <option value="Prefer not to say">Prefer not to say</option>
                            </InputSelect>
                            <ValidationMessage For="() => model.Gender" class="text-danger small" />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Marital Status</label>
                            <InputSelect @bind-Value="model.MaritalStatus" class="form-select">
                                <option value="">-- Select --</option>
                                <option value="Single">Single</option>
                                <option value="Married">Married</option>
                                <option value="Divorced">Divorced</option>
                                <option value="Widowed">Widowed</option>
                                <option value="Prefer not to say">Prefer not to say</option>
                            </InputSelect>
                        </div>
                    </div>

                    <!-- Address -->
                    <h5 class="section-title mt-3"><i class="fas fa-map-marker-alt me-2"></i>Address</h5>
                    <div class="mb-3">
                        <label class="form-label">Street Address</label>
                        <InputText @bind-Value="model.Address" class="form-control" placeholder="123 Main St" />
                    </div>
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label">City</label>
                            <InputText @bind-Value="model.City" class="form-control" placeholder="City" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">State / Province</label>
                            <InputText @bind-Value="model.State" class="form-control" placeholder="State" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Postal Code</label>
                            <InputText @bind-Value="model.PostalCode" class="form-control" placeholder="12345" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Country</label>
                        <InputText @bind-Value="model.Country" class="form-control" placeholder="Country" />
                    </div>

                    <!-- Professional Information -->
                    <h5 class="section-title mt-3"><i class="fas fa-briefcase me-2"></i>Professional Information</h5>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Occupation</label>
                            <InputText @bind-Value="model.Occupation" class="form-control" placeholder="e.g. Software Engineer" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Employer / Company</label>
                            <InputText @bind-Value="model.Employer" class="form-control" placeholder="Company name" />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Years of Experience</label>
                            <InputNumber @bind-Value="model.YearsOfExperience" class="form-control" min="0" max="60" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">LinkedIn Profile URL</label>
                            <InputText @bind-Value="model.LinkedInUrl" class="form-control" placeholder="https://linkedin.com/in/yourprofile" />
                            <ValidationMessage For="() => model.LinkedInUrl" class="text-danger small" />
                        </div>
                    </div>

                    <!-- Academic Information -->
                    <h5 class="section-title mt-3"><i class="fas fa-graduation-cap me-2"></i>Academic Information</h5>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Institution / University <span class="text-danger">*</span></label>
                            <InputText @bind-Value="model.Institution" class="form-control" placeholder="University name" />
                            <ValidationMessage For="() => model.Institution" class="text-danger small" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Degree <span class="text-danger">*</span></label>
                            <InputSelect @bind-Value="model.Degree" class="form-select">
                                <option value="">-- Select Degree --</option>
                                <option value="High School Diploma">High School Diploma</option>
                                <option value="Associate's">Associate's</option>
                                <option value="Bachelor's">Bachelor's</option>
                                <option value="Master's">Master's</option>
                                <option value="Doctorate">Doctorate</option>
                                <option value="Professional">Professional</option>
                                <option value="Certificate">Certificate</option>
                            </InputSelect>
                            <ValidationMessage For="() => model.Degree" class="text-danger small" />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Field of Study <span class="text-danger">*</span></label>
                            <InputText @bind-Value="model.FieldOfStudy" class="form-control" placeholder="e.g. Computer Science" />
                            <ValidationMessage For="() => model.FieldOfStudy" class="text-danger small" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Graduation Year</label>
                            <InputNumber @bind-Value="model.GraduationYear" class="form-control" min="1950" max="2040" />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label">GPA</label>
                            <InputText @bind-Value="model.GradePointAverage" class="form-control" placeholder="e.g. 3.8" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Student ID</label>
                            <InputText @bind-Value="model.StudentId" class="form-control" placeholder="Student ID number" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Academic Year</label>
                            <InputSelect @bind-Value="model.AcademicYear" class="form-select">
                                <option value="">-- Select --</option>
                                <option value="100lvl (Freshman)">100lvl (Freshman)</option>
                                <option value="200lvl (Sophomore)">200lvl (Sophomore)</option>
                                <option value="300lvl (Junior)">300lvl (Junior)</option>
                                <option value="400lvl (Senior)">400lvl (Senior)</option>
                                <option value="500lvl (Senior)">500lvl (Senior)</option>
                                <option value="600lvl (Senior)">600lvl (Senior)</option>
                                <option value="Postgraduate">Postgraduate</option>
                                <option value="Graduate">Graduate</option>
                                <option value="Alumni">Alumni</option>
                            </InputSelect>
                        </div>
                    </div>
                    <div class="mb-4">
                        <label class="form-label">Certifications</label>
                        <InputTextArea @bind-Value="model.Certifications" class="form-control" rows="3" />
                    </div>

                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary btn-lg" disabled="@isLoading">
                            @if (isLoading)
                            {
                                <span class="spinner-border spinner-border-sm me-2"></span>
                            }
                            <i class="fas fa-user-plus me-2"></i>Create Account
                        </button>
                    </div>
                    <div class="text-center mt-3">
                        <span class="text-muted">Already have an account?</span>
                        <a href="/account/login" class="ms-1">Sign in here</a>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
</div>
